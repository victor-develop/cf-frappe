{
  "name": "cf-frappe",
  "version": "0.1.0",
  "description": "A metadata-driven, event-sourced application framework for Cloudflare Workers.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare/index.d.ts",
      "import": "./dist/cloudflare/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "cf-frappe": "./dist/cli.js"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run build",
    "dev": "wrangler dev --persist-to=.wrangler/state",
    "deploy": "wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply cf-frappe-dev --local",
    "d1:migrate:remote": "wrangler d1 migrations apply cf-frappe-dev --remote"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "frappe",
    "event-sourcing",
    "durable-objects",
    "d1",
    "metadata-driven"
  ],
  "dependencies": {
    "hono": "^4.6.17"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@types/node": "^26.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
